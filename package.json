{
  "name": "tedography",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev:web": "pnpm --filter @tedography/web dev",
    "dev:api": "pnpm --filter @tedography/api dev",
    "dev": "concurrently \"pnpm:dev:web\" \"pnpm:dev:api\"",
    "thumbnails:verify": "pnpm --filter @tedography/api thumbnails:verify",
    "thumbnails:repair": "pnpm --filter @tedography/api thumbnails:repair",
    "thumbnails:rebuild": "pnpm --filter @tedography/api thumbnails:rebuild",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "9.2.1",
    "rimraf": "6.1.3",
    "typescript": "5.9.3"
  }
}
