{
  "name": "@tedography/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "debug": "tsx src/index.ts",
    "assets:verify": "tsx src/tools/assetIntegrityVerification.ts",
    "locations:backfill": "tsx src/tools/backfillAssetLocations.ts",
    "thumbnails:verify": "tsx src/tools/thumbnailMaintenance.ts --mode verify",
    "thumbnails:repair": "tsx src/tools/thumbnailMaintenance.ts --mode repair",
    "thumbnails:rebuild": "tsx src/tools/thumbnailMaintenance.ts --mode rebuild",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.914.0",
    "@tedography/domain": "workspace:*",
    "@tedography/duplicate-domain": "workspace:*",
    "@tedography/import-pipeline": "workspace:*",
    "@tedography/media-metadata": "workspace:*",
    "@tedography/shared": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "exiftool-vendored": "^31.1.0",
    "express": "5.2.1",
    "mongoose": "9.2.4",
    "openai": "^6.35.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "5.0.6",
    "@types/node": "25.3.5",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
