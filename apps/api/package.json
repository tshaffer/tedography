{
  "name": "@tedography/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "debug": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tedography/domain": "workspace:*",
    "@tedography/import-pipeline": "workspace:*",
    "@tedography/media-metadata": "workspace:*",
    "@tedography/shared": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "5.2.1",
    "mongoose": "9.2.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "5.0.6",
    "@types/node": "25.3.5",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
