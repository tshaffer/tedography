{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Kill Port 4000",
      "type": "shell",
      "command": "lsof -ti :4000 | xargs kill -9 2>/dev/null || true",
      "presentation": {
        "reveal": "never"
      },
      "problemMatcher": []
    },
    {
      "label": "Tedography Web Dev",
      "type": "shell",
      "command": "pnpm --filter @tedography/web dev",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "owner": "custom",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^(ERROR in) (.*)$",
          "file": 2,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "webpack serve",
          "endsPattern": "compiled successfully"
        }
      }
    }
  ]
}