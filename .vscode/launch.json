{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Tedography API",
      "type": "pwa-node",
      "request": "launch",
      "preLaunchTask": "Kill Port 4000",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--import",
        "tsx",
        "--enable-source-maps"
      ],
      "program": "${workspaceFolder}/apps/api/src/index.ts",
      "env": {
        "PORT": "4000"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug Tedography Web",
      "type": "pwa-chrome",
      "request": "launch",
      "preLaunchTask": "Tedography Web Dev",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/apps/web"
    }
  ],
  "compounds": [
    {
      "name": "Debug Tedography Full Stack",
      "configurations": [
        "Debug Tedography API",
        "Debug Tedography Web"
      ]
    }
  ]
}
