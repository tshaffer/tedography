{
  "name": "Tedography Album Label to Recommended Keyword Mapping",
  "version": 1,
  "notes": [
    "This file maps existing album labels to suggested Tedography keyword labels.",
    "Keyword labels here are intended to match the recommended keyword tree previously generated.",
    "Some album labels map to no normal keywords because they are organizational, operational, date-bucket, or source-bucket constructs.",
    "A single album label may map to multiple keywords.",
    "This is a starting point for curation and backfill, not a claim that every album should always receive all mapped keywords."
  ],
  "mappingCategories": {
    "direct": "Direct album label to one or more recommended keywords",
    "normalized": "Album label maps to normalized canonical keyword(s)",
    "albumOnly": "Album should usually remain album-only and not map to normal keywords"
  },
